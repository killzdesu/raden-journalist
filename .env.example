# Optional, use if you have one to increase rate limits to 10/sec instead of 3/sec
NCBI_API_KEY=your_ncbi_api_key

# LLM setup (Google Gemini main, OpenRouter backup)
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=your_gemini_api_key

BACKUP_LLM_PROVIDER=openrouter
BACKUP_LLM_MODEL=gpt-5.4-mini
OPENROUTER_API_KEY=your_openrouter_api_key

SIMPLE_TASK_LLM_PROVIDER=openrouter
SIMPLE_TASK_LLM_MODEL=openrouter/free
SIMPLE_TASK_LLM_API_KEY=openrouter_api_key

# Discord
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Search Settings
LOOKBACK_DAYS=3
MAX_ARTICLES_PER_RUN=10
LOG_SIZE_LIMIT_MB=10
